<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Rolling file — /opt/sfb/logs/app.log, daily rotation, 30-day retention -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/opt/sfb/logs/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/opt/sfb/logs/app.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Async wrapper — decouples logging I/O from application threads -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="FILE"/>
        <!-- Drop TRACE/DEBUG when queue is 80% full; never drop WARN/ERROR -->
        <discardingThreshold>20</discardingThreshold>
        <queueSize>512</queueSize>
    </appender>

    <!-- Console — captured by systemd journal (journalctl -u sfb) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Reduce noise from third-party libraries -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.telegram"        level="WARN"/>
    <logger name="okhttp3"             level="WARN"/>

    <!-- Application packages at INFO -->
    <logger name="boats.log.shippingforecast" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="ASYNC_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
